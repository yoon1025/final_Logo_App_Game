rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return true; // Allowing anonymous/unauthenticated access for this simple game
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['id', 'name', 'score', 'time']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 20 &&
             data.score is int && data.score >= 0 &&
             data.time is int && data.time >= 0;
    }

    match /leaderboard/{playerId} {
      // Allow anyone to read the leaderboard
      allow read: if true;
      
      // Allow creation of a new record
      allow create: if isValidPlayer(request.resource.data);
      
      // Allow update only if the new score is better (higher score or same score with less time)
      allow update: if isValidPlayer(request.resource.data) && (
        request.resource.data.score > resource.data.score || 
        (request.resource.data.score == resource.data.score && request.resource.data.time < resource.data.time)
      );

      // Allow deletion for reset (In a production app, this should be restricted to admins)
      allow delete: if true;
    }
  }
}
